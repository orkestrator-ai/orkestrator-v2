{
  "name": "@orkestrator/backend",
  "version": "2.3.0",
  "private": true,
  "type": "module",
  "exports": {
    "./gateway": "./src/gateway.ts"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun --watch src/main.ts",
    "dev:web": "bun --watch src/main.ts --port 34121 --fallback-host 127.0.0.1 --renderer-dev-server-url http://127.0.0.1:1420",
    "start": "bun dist/main.js",
    "start:web": "bun dist/main.js --fallback-host 127.0.0.1",
    "start:web-public": "bun dist/main.js --tailscale-serve --allowed-origins https://orkestrator.dev,https://www.orkestrator.dev",
    "test": "bun test src tests",
    "test:workspace": "bun test src tests",
    "typecheck": "bunx tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@orkestrator/protocol": "workspace:*",
    "sharp": "^0.35.1"
  }
}
