{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:workspace": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:web": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["ORKESTRATOR_*", "VITE_DEV_HOST"]
    },
    "start:web": {
      "dependsOn": ["build", "@orkestrator/web#build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["ORKESTRATOR_*"]
    }
  }
}
